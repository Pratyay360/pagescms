{
  "name": "pagescms",
  "version": "2.1.6",
  "private": true,
  "description": "A user-friendly CMS for Next.js, Astro, Hugo, Nuxt, Jekyll or any other static site generator.",
  "license": "MIT",
  "author": {
    "name": "Ronan Berder"
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "setup:github-app": "node scripts/setup-github-app.mjs",
    "dev": "next dev",
    "build": "next build",
    "postbuild": "npm run db:migrate",
    "start": "next start",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "auth:generate": "npx @better-auth/cli generate --config ./lib/auth.ts --output ./auth-schema.ts --yes",
    "db:clear-cache": "npx tsx db/scripts/clear-cache.ts",
    "db:collaborators:export": "npx tsx db/scripts/collaborators/export.ts",
    "db:collaborators:import": "npx tsx db/scripts/collaborators/import.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@ltd/j-toml": "^1.38.0",
    "@next/env": "^16.2.6",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/extension-table-cell": "^3.23.1",
    "@tiptap/extension-table-header": "^3.23.1",
    "@tiptap/extension-table-row": "^3.23.1",
    "@tiptap/extension-underline": "^3.23.1",
    "@tiptap/markdown": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@tiptap/suggestion": "^3.23.1",
    "@types/nodemailer": "^8.0.0",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/codemirror-theme-xcode": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "lodash.merge": "^4.6.2",
    "lodash.mergewith": "^4.6.2",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "nextjs": "^0.0.3",
    "nodemailer": "^8.0.7",
    "postcss": "^8.5.14",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-email": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "resend": "^6.12.3",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.4",
    "use-debounce": "^10.1.1",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-email/ui": "^6.1.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/lodash.merge": "^4.6.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.10",
